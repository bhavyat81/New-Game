{
  "expo": {
    "name": "Hardware Havildar",
    "slug": "hardware-havildar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ui/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ui/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF8C00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hardwarehavildar.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ui/adaptive-icon.png",
        "backgroundColor": "#FF8C00"
      },
      "package": "com.hardwarehavildar.app"
    },
    "scheme": "hardware-havildar",
    "plugins": [
      "expo-router"
    ]
  }
}
